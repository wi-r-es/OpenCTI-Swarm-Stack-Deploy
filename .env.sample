RABBITMQ_DEFAULT_PASS=changeme
SMTP_HOSTNAME=localhost
ELASTIC_MEMORY_SIZE=4G

###########################
# COMMON                  #
###########################

XTM_COMPOSER_ID=<UUIDv4>
COMPOSE_PROJECT_NAME=opencti

###########################
# OPENCTI                 #
###########################

OPENCTI_VERSION=7.260409.0
OPENCTI_HOST=<IP_addr>
