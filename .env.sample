OPENCTI_EXTERNAL_SCHEME=http
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=changeme
OPENCTI_ADMIN_TOKEN=<UUIDv4>
OPENCTI_HEALTHCHECK_ACCESS_KEY=<UUIDv4>
OPENCTI_ENCRYPTION_KEY=<base64_enc_key>

###########################
